# Esse Jeffe — cache ve güvenlik header'ları
# Netlify ve Cloudflare Pages bu dosyayı otomatik okur.
# JS/CSS sürümleme ?v=N ile yapıldığı için 1 saatlik cache + SWR güvenli;
# görseller içerik değişince dosya adı da değiştiğinden 1 yıl immutable.

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), payment=()
  Strict-Transport-Security: max-age=86400
  Content-Security-Policy-Report-Only: default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://unpkg.com https://www.paytr.com https://www.googletagmanager.com https://connect.facebook.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https://grdinhjtsmoograktgge.supabase.co wss://grdinhjtsmoograktgge.supabase.co https://api.pwnedpasswords.com https://www.google-analytics.com https://region1.google-analytics.com https://www.facebook.com; frame-src https://www.paytr.com; frame-ancestors 'self'; base-uri 'self'; form-action 'self'; object-src 'none'

/*.html
  Cache-Control: public, max-age=0, must-revalidate

/img/*
  Cache-Control: public, max-age=31536000, immutable

/*.js
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

/*.css
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

/backend/*.js
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400
